# Hive Backend Environment Variables
# Copy this file to `.env` and fill in the values

# REQUIRED: JWT signing key (generate with: openssl rand -hex 32)
SECRET_KEY=

# Database (default: SQLite for dev, switch to PostgreSQL for production)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/hive

# Apple IAP shared secret (from App Store Connect)
APPLE_SHARED_SECRET=

# SMTP email configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@hiveapp.com

# CORS allowed origins (comma-separated)
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
